{
  "policy_mode": "strict",
  "files": {
    "allowed_extensions": [".js", ".json", ".md"],
    "allowed_filenames": ["controller.js", "manifest.json", "README.md"]
  },
  "commands": {
    "allowed_commands": [
      "npm test",
      "npm run build"
    ],
    "allowed_prefixes": [],
    "blocklist": [
      "rm -rf",
      "curl",
      "wget",
      "sudo",
      "mv"
    ]
  }
}
