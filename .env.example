# LLM Provider Configuration
# Supported providers: ollama (local), minimax (cloud), or any OpenAI-compatible provider
LLM_PROVIDER=minimax

# MiniMax model choices: abab6.5g-chat, abab6.5s-chat
LLM_MODEL=abab6.5g-chat

# API Endpoint URL for MiniMax v2 API (OpenAI compatible)
LLM_API_URL=https://api.minimax.chat/v1/text/chatcompletion_v2

# Your MiniMax API key/token
LLM_API_KEY=your_minimax_api_key_here

# Optional: Custom Ollama endpoint if running locally
# OLLAMA_API_URL=http://localhost:11434/api/generate

# 设置为 false 将忽略系统代理，直接连接大模型接口
LLM_TRUST_ENV=false

# OpenCode Developer Agent CLI Configuration
# For global installation: opencode
# For local submodule: bun run --cwd vendor/opencode dev
OPENCODE_COMMAND=opencode

# OpenCode Developer Agent execution timeout (in seconds)
# Default is 600.0 (10 minutes)
OPENCODE_TIMEOUT=600.0