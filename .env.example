# LLM providers and model selection are configured from the Ambient Agent UI.
# Stored credentials live in the gitignored workspace/llm/secrets.json file.
# Individual credential fields may reference deployment environment variables.

# OpenCode Developer Agent CLI Configuration
# In Docker / DevContainer, the latest opencode binary is automatically pulled
# via the official installer and placed at /usr/local/bin/opencode, so the
# default value below works out of the box.
# For a global installation on the host:        opencode
# For a local submodule / dev build:            bun run --cwd vendor/opencode dev
OPENCODE_COMMAND=opencode

# OpenCode Developer Agent execution timeout (in seconds)
# Default is 600.0 (10 minutes)
OPENCODE_TIMEOUT=600.0

# Codex runs only on the host so it can reuse the user's local login and
# ChatGPT subscription. Generate a secret with `openssl rand -hex 32`, put the
# same value here, then start `uv run python -m scripts.codex_host_bridge` on
# the host before selecting Codex in the UI.
CODEX_HOST_BRIDGE_URL=http://host.docker.internal:8765
CODEX_HOST_BRIDGE_TOKEN=
CODEX_HOST_COMMAND=codex
CODEX_HOST_BRIDGE_BIND=127.0.0.1
CODEX_HOST_BRIDGE_PORT=8765
AMBIENT_HOST_WORKSPACE_DIR=workspace
CODEX_TIMEOUT=600.0
